rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/technicians/$(request.auth.uid)).data.role == 'admin';
    }
    function isAssignedToSite(siteId) {
      return isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/sites/$(siteId)).data.assignedTo;
    }

    match /technicians/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    match /technicianLookup/{techNumber} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /sites/{siteId} {
      // Read: admins or assigned technicians
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.assignedTo);

      // Create & delete reserved for admins
      allow create: if isAdmin();
      allow delete: if isAdmin();

      // Updates: admins may update anything; assigned technicians may only update a restricted set of fields
      allow update: if isAdmin()
        || (
          isSignedIn()
          && request.auth.uid in resource.data.assignedTo
          && request.resource.data.keys().hasOnly(['name', 'address', 'notes', 'category', 'assignedTo', 'completed', 'completedAt', 'lastCompletedDate', 'lastCompletedBy', 'createdAt'])
        );
    }

    match /equipment/{eqId} {
      allow read, update, delete: if isAdmin() || (isSignedIn() && isAssignedToSite(resource.data.siteId));
      allow create: if isAdmin() || (isSignedIn() && isAssignedToSite(request.resource.data.siteId));
    }
  }
}
